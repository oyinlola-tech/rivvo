# Frontend environment variables
# Required in production builds served by Vite.

# Base URL of the backend API (no trailing slash).
VITE_API_URL=https://rivvo-api.telente.site/api

# Optional ICE servers for WebRTC (array of RTCIceServer objects)
# Example:
# VITE_ICE_SERVERS=[{"urls":["stun:stun.l.google.com:19302"]},{"urls":"turn:turn.example.com:3478","username":"user","credential":"pass"}]
