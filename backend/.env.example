# Backend environment variables
# Copy to backend/.env and fill with production values.

# Server
PORT=3000
NODE_ENV=production

# Frontend origins (CORS)
CLIENT_URL=https://rivvo.telente.site
CLIENT_URLS=https://rivvo.telente.site,https://www.rivvo.telente.site

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=rivvo

# Auth
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_DAYS=30
OTP_EXPIRES_MINUTES=10

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=Rivvo <no-reply@rivvo.com>

# Call room link base
CALL_ROOM_BASE_URL=https://rivvo.telente.site/call/

# Rate limiting
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_API_MAX=300

# Bootstrap admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_strong_password
ADMIN_NAME=Rivvo Admin
UPLOADS_DIR=/absolute/path/to/uploads
